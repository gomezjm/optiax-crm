# Dashboard env (spec §5). Local values come from `supabase start` output.
# Anon key ONLY — the service-role key must never appear in the dashboard.

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon key from `supabase start`>

# Runtime base URL for the Playground / Publish calls (ws-d3). Local dev default.
NEXT_PUBLIC_RUNTIME_URL=http://localhost:8787
