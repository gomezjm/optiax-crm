# Runtime env (spec §5). Local values come from `supabase start` output.
# Without a .env.local the runtime falls back to the local supabase-demo
# defaults for SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY (dev only).

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=<service_role key from `supabase start`>

# Real key → real Gemini calls. Unset → FakeModel (canned replies, no network).
GEMINI_API_KEY=
GEMINI_MODEL_ID=gemini-2.5-flash

# Shared secret for the stub webhook signature scheme (defaults to the dev
# secret baked into @optiax/shared when unset — fine locally).
WEBHOOK_SECRET=

# mock | 360dialog (360dialog sender lands in Phase 4)
WA_SENDER=mock

PORT=8787
